# =========================================================
#  Pelican Muay Thai — .htaccess (OVH / Apache)
#  Refonte WordPress -> site statique
# =========================================================

# ---------------------------------------------------------
# 1) Forcer HTTPS + www (1 seule version canonique = bon SEO)
#    /!\ Activer d'abord le certificat SSL gratuit sur OVH,
#        sinon le site sera inaccessible.
# ---------------------------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.pelicanmuaythai.fr%{REQUEST_URI} [L,R=301]

# ---------------------------------------------------------
# 2) Redirections 301 des anciennes URLs WordPress
#    (les plus precises d'abord)
# ---------------------------------------------------------
RedirectMatch 301 ^/adhesion/cours-dessai-gratuit/?$   https://www.pelicanmuaythai.fr/adhesion.html
RedirectMatch 301 ^/adhesion/?$                         https://www.pelicanmuaythai.fr/adhesion.html
RedirectMatch 301 ^/horaires/?$                         https://www.pelicanmuaythai.fr/cotisations-formules.html
RedirectMatch 301 ^/tarif/?$                            https://www.pelicanmuaythai.fr/cotisations-formules.html
RedirectMatch 301 ^/le-club/dossier-competition/?$      https://www.pelicanmuaythai.fr/
RedirectMatch 301 ^/le-club/galerie/?$                  https://www.pelicanmuaythai.fr/
RedirectMatch 301 ^/le-club/?$                          https://www.pelicanmuaythai.fr/
RedirectMatch 301 ^/infos/mentions-legales/?$           https://www.pelicanmuaythai.fr/mentions-legales.html
RedirectMatch 301 ^/infos/?$                            https://www.pelicanmuaythai.fr/adhesion.html
RedirectMatch 301 ^/newsletter/?$                       https://www.pelicanmuaythai.fr/

# ---------------------------------------------------------
# 3) Page 404 personnalisee
# ---------------------------------------------------------
ErrorDocument 404 /404.html

# ---------------------------------------------------------
# 4) Compression GZIP (fichiers texte plus legers)
# ---------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# ---------------------------------------------------------
# 5) Cache navigateur (le visiteur ne recharge pas tout a chaque visite)
# ---------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # Images, polices : 1 an (elles changent rarement)
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
  ExpiresByType font/woff2              "access plus 1 year"
  # CSS / JS : 1 mois
  ExpiresByType text/css                "access plus 1 month"
  ExpiresByType application/javascript  "access plus 1 month"
  # HTML : pas de cache long (pour voir les mises a jour tout de suite)
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>
